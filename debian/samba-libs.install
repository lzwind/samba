#!/usr/bin/dh-exec --with-scripts=filter-build-profiles
# when there are any real changes in the publically visible libs (usr/lib/${DEB_HOST_MULTIARCH}/libfoo.so.N*),
# especially the soname changes, check for pkgs which depend on samba-libs (eg sssd-ad)
# and add Breaks for packages/versions using old libs to d/control
# Here, always specify libs with soname (libfoo.so.1*, not libfoo.so.*)
# Not all of the below public libraries are actually public
usr/lib/${DEB_HOST_MULTIARCH}/libdcerpc-binding.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libdcerpc-samr.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libdcerpc-server-core.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libdcerpc-server.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libdcerpc.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libndr-krb5pac.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libndr-nbt.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libndr-standard.so.0*
usr/lib/${DEB_HOST_MULTIARCH}/libndr.so.6*
usr/lib/${DEB_HOST_MULTIARCH}/libnetapi.so.1*
usr/lib/${DEB_HOST_MULTIARCH}/libsamba-credentials.so.1*
usr/lib/${DEB_HOST_MULTIARCH}/libsamba-errors.so.1*
