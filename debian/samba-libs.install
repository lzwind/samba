usr/lib/${DEB_HOST_MULTIARCH}/libsmbldap.so.2*
usr/lib/${DEB_HOST_MULTIARCH}/libtevent-util.so.0*
# heimdal libraries (used by samba and winbind)
<!pkg.samba.mitkrb5> usr/lib/${DEB_HOST_MULTIARCH}/samba/libasn1-private-samba.so.0
<!pkg.samba.mitkrb5> usr/lib/${DEB_HOST_MULTIARCH}/samba/libcom-err-private-samba.so.0
<!pkg.samba.mitkrb5> usr/lib/${DEB_HOST_MULTIARCH}/samba/libgssapi-private-samba.so.0
