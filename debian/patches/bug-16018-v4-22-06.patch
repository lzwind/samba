 create mode 100644 selftest/knownfail.d/vfs-worm

#diff --git a/selftest/knownfail.d/vfs-worm b/selftest/knownfail.d/vfs-worm
#new file mode 100644
#index 00000000000..f4a330c744b
#--- /dev/null
